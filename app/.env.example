# ============================================================
# .env.example — Plantilla de variables de entorno para CyberShop
# Copia este archivo como .env y rellena los valores reales.
# ============================================================

# --- Flask ---
FLASK_SECRET_KEY=cambia-esto-por-una-clave-aleatoria-segura

# --- Base de Datos PostgreSQL ---
DB_NAME=cybershop
DB_USER=postgres
DB_PASSWORD=tu_password_postgres
DB_HOST=localhost
DB_PORT=5432

# --- PayU Latam ---
PAYU_API_KEY=tu_payu_api_key
PAYU_API_LOGIN=tu_payu_api_login
PAYU_MERCHANT_ID=tu_merchant_id
PAYU_ACCOUNT_ID=tu_account_id
PAYU_ENV=sandbox
PAYU_RESPONSE_URL=http://localhost:5001/respuesta-pago
PAYU_CONFIRMATION_URL=http://localhost:5001/confirmacion-pago

# --- Gmail SMTP ---
# Usar una "Contraseña de aplicación" de Google (no la contraseña principal)
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_sin_espacios
MAIL_DEFAULT_SENDER=tu_correo@gmail.com

# --- Google OAuth 2.0 ---
# Crear en: https://console.cloud.google.com → APIs → Credenciales → OAuth 2.0
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=http://localhost:5001/admin/google/callback
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:5001/google/login/callback

# --- Datos de Facturación (Cuentas de Cobro) ---
BILLING_NOMBRE=Tu Nombre Completo
BILLING_ID=tu_numero_cedula
BILLING_TELEFONO=tu_telefono
BILLING_EMAIL=tu_email@ejemplo.com
BILLING_TEXTO_PAGO=Texto de autorización de pago personalizado
