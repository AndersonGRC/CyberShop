# ── Logs y procesos ──────────────────────────────────────
nohup.out
*.log
logs/

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Entornos virtuales ───────────────────────────────────
venv/
.venv/
env/
.env

